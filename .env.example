# --- Required for production ---
# MongoDB connection (Atlas or self-hosted). Example:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=

# Strong random string — min 16 characters (e.g. openssl rand -hex 32)
JWT_SECRET=

# Exact browser origin of your Next.js site (no trailing slash). Used for CORS.
# Example: https://your-app.vercel.app
CLIENT_URL=

# --- Optional ---
# Extra allowed origins (comma or space separated), e.g. preview URL + custom domain.
# ALLOWED_ORIGINS=https://preview-123.vercel.app,https://www.example.com

# PORT is set automatically on most hosts (Railway, Render, Fly). Default 5000 locally.
# PORT=5000

# Bind address (default 0.0.0.0 so the process accepts external connections in containers)
# HOST=0.0.0.0

# Set on PaaS behind a reverse proxy if you rely on req.ip / X-Forwarded-* .
# TRUST_PROXY=1

# --- AI (optional; /api/recommend works with rules; keys enable enhancement) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=

# Set to 0 to skip inserting/activating the default course catalog when no active courses exist.
# AUTO_SEED_DEFAULT_COURSES=0

# Demo users only (npm run seed:users) — min 8 characters; never use in production DB with real data.
# SEED_DEMO_PASSWORD=

# --- Admin seed (scripts/seed-admin.js only) ---
# ADMIN_EMAIL=
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# ADMIN_NAME=Admin
